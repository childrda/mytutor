  "web_search": {
    "tavily": {
      "provider": "tavily",
      "endpoint": "https://api.tavily.com/search",
      "request_format": {
        "api_key": "{api_key}",
        "query": "{query}",
        "max_results": "{max_results|10}",
        "search_depth": "{search_depth|basic}"
      },
      "response_path": "results",
      "auth_header": null,
      "auth_scheme": null,
      "_note": "API key in JSON body; no Bearer header."
    }
  }
}
