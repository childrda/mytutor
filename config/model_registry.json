    "minimax-video": {
      "provider": "minimax",
      "endpoint": "{base_url}/v1/video_generation",
      "request_format": {
        "model": "{model|MiniMax-Hailuo-2.3}",
        "prompt": "{prompt}"
      },
      "response_path": "task_id",
      "auth_header": "Authorization",
