{
    "schema_version": 1,
    "_meta": {
        "note": "Phase 2 \u2014 dynamic model list (was monolithic model_registry.json). Each entry id is the registry key for tutor.active.* and Settings.",
        "migrated_from": "model_registry.json"
    },
    "llm": [
        {
            "provider": "openai",
            "endpoint": "{base_url}/chat/completions",
            "request_format": {
                "model": "{model|gpt-4o-mini}",
                "messages": "{messages}",
                "temperature": "{temperature|0.7}",
                "max_completion_tokens": "{max_completion_tokens|2048}"
            },
            "response_path": "choices[0].message.content",
            "auth_header": "Authorization",
            "auth_scheme": "Bearer {api_key}",
            "_note": "Use max_tokens instead of max_completion_tokens for Ollama/LM Studio (see tutor.llm_completion_limit_param).",
            "id": "openai",
            "display_name": "OpenAI",
            "enabled": true,
            "base_url": "https://api.openai.com/v1"
        },
        {
            "provider": "anthropic",
            "endpoint": "{base_url|https://api.anthropic.com/v1}/messages",
            "llm_input_wire": "anthropic_messages",
            "request_headers": {
                "anthropic-version": "2023-06-01"
            },
            "request_format": {
                "model": "{model|claude-sonnet-4-20250514}",
                "max_tokens": "{max_tokens|4096}",
                "temperature": "{temperature|0.7}",
                "system": "{system|}",
                "messages": "{messages}"
            },
            "response_path": "content[0].text",
            "auth_header": "x-api-key",
            "auth_scheme": "{api_key}",
            "_note": "OpenAI-shaped caller messages are normalized in RegistryLlmMessageNormalizer (system split, user/assistant only).",
            "id": "anthropic",
            "display_name": "Anthropic",
            "enabled": true,
            "base_url": "https://api.anthropic.com/v1"
        },
        {
            "provider": "google",
            "endpoint": "{base_url}/v1beta/models/{model|gemini-2.0-flash}:generateContent",
            "llm_input_wire": "google_generate_content",
            "request_format": {
                "contents": "{contents}",
                "systemInstruction": {
                    "parts": [
                        {
                            "text": "{system|}"
                        }
                    ]
                },
                "generationConfig": {
                    "temperature": "{temperature|0.7}",
                    "maxOutputTokens": "{max_output_tokens|2048}"
                }
            },
            "response_path": "candidates[0].content.parts[0].text",
            "auth_header": "X-Goog-Api-Key",
            "auth_scheme": "{api_key}",
            "_note": "Typical Gemini base is https://generativelanguage.googleapis.com. Caller messages normalized to contents + optional systemInstruction.",
            "id": "google",
            "display_name": "Google",
            "enabled": true,
            "base_url": "https://generativelanguage.googleapis.com"
        },
        {
            "provider": "deepseek",
            "endpoint": "{base_url|https://api.deepseek.com/v1}/chat/completions",
            "request_format": {
                "model": "{model|deepseek-chat}",
                "messages": "{messages}",
                "temperature": "{temperature|0.7}",
                "max_tokens": "{max_tokens|2048}"
            },
            "response_path": "choices[0].message.content",
            "auth_header": "Authorization",
            "auth_scheme": "Bearer {api_key}",
            "id": "deepseek",
            "display_name": "Deepseek",
            "enabled": true,
