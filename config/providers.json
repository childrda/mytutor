    "minimax": {
      "name": "MiniMax",
      "icon": "minimax",
      "capabilities": ["llm", "video"],
      "base_url": "{base_url}",
      "auth_header": "Authorization",
      "auth_scheme": "Bearer {api_key}",
      "env_key": "MINIMAX_API_KEY",
      "supports_custom_base_url": true,
      "_note": "LLM base often OpenAI-compatible; video uses tutor.video_generation.base_url when polling."
    },
    "glm": {
      "name": "GLM",
      "icon": "glm",
      "capabilities": ["llm"],
      "base_url": "{base_url}",
      "auth_header": "Authorization",
      "auth_scheme": "Bearer {api_key}",
