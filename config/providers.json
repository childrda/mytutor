{
  "schema_version": 1,
  "_meta": {
    "note": "Developer-managed provider catalog (Phase 2). Provider ids must match the \"provider\" field on rows in config/models.json."
  },
  "providers": {
    "openai": {
      "name": "OpenAI",
      "icon": "openai",
      "capabilities": ["llm", "image", "tts", "asr"],
      "base_url": "https://api.openai.com/v1",
      "auth_header": "Authorization",
      "auth_scheme": "Bearer {api_key}",
      "env_key": "OPENAI_API_KEY",
      "supports_custom_base_url": false,
      "request_templates": {
        "llm": {
          "model": "{model_id}",
          "messages": "{messages}",
          "temperature": "{temperature|0.7}",
          "max_completion_tokens": "{max_completion_tokens|2048}"
        },
        "image": {
          "model": "{model_id}",
          "prompt": "{prompt}",
          "n": 1,
          "size": "{size|1024x1024}"
        }
      }
    },
    "anthropic": {
      "name": "Anthropic",
      "icon": "anthropic",
      "capabilities": ["llm"],
      "base_url": "https://api.anthropic.com/v1",
      "auth_header": "x-api-key",
      "auth_scheme": "{api_key}",
      "env_key": "ANTHROPIC_API_KEY",
      "supports_custom_base_url": false
    },
    "google": {
      "name": "Google AI Studio / Gemini",
      "icon": "google",
      "capabilities": ["llm"],
      "base_url": "https://generativelanguage.googleapis.com",
      "auth_header": "X-Goog-Api-Key",
      "auth_scheme": "{api_key}",
      "env_key": "GOOGLE_API_KEY",
      "supports_custom_base_url": false
    },
    "groq": {
      "name": "Groq",
      "icon": "groq",
      "capabilities": ["llm", "asr"],
      "base_url": "https://api.groq.com/openai/v1",
      "auth_header": "Authorization",
      "auth_scheme": "Bearer {api_key}",
      "env_key": "GROQ_API_KEY",
      "supports_custom_base_url": false
    },
    "deepseek": {
      "name": "DeepSeek",
      "icon": "deepseek",
      "capabilities": ["llm"],
      "base_url": "https://api.deepseek.com/v1",
      "auth_header": "Authorization",
      "auth_scheme": "Bearer {api_key}",
      "env_key": "DEEPSEEK_API_KEY",
      "supports_custom_base_url": true
    },
    "qwen": {
      "name": "Qwen (OpenAI-compatible)",
      "icon": "qwen",
      "capabilities": ["llm"],
      "base_url": "{base_url}",
      "auth_header": "Authorization",
      "auth_scheme": "Bearer {api_key}",
      "env_key": "QWEN_API_KEY",
      "supports_custom_base_url": true,
      "_note": "Set QWEN_BASE_URL + QWEN_API_KEY"
    },
    "kimi": {
      "name": "Kimi",
      "icon": "kimi",
      "capabilities": ["llm"],
      "base_url": "{base_url}",
      "auth_header": "Authorization",
      "auth_scheme": "Bearer {api_key}",
      "env_key": "KIMI_API_KEY",
      "supports_custom_base_url": true
