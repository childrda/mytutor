APP_NAME=MyTutor
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mytutor
DB_USERNAME=root
DB_PASSWORD=

# PHPUnit (see phpunit.xml) defaults to DB_DATABASE=mytutor_test — create it so tests do not wipe your dev DB:
# mysql -u root -p -e "CREATE DATABASE IF NOT EXISTS mytutor_test;"
# Run tests with: DB_PASSWORD=your_password php artisan test

# -----------------------------------------------------------------------------
# Tutor: default LLM (lesson generation, server chat fallback, quiz grading, …)
# Falls back: TUTOR_DEFAULT_LLM_API_KEY → OPENAI_API_KEY
# -----------------------------------------------------------------------------
TUTOR_DEFAULT_LLM_API_KEY=
TUTOR_DEFAULT_LLM_BASE_URL=https://api.openai.com/v1
TUTOR_DEFAULT_LLM_MODEL=gpt-4o-mini

# Chat completions limit field: unset = max_completion_tokens (OpenAI GPT-5+). For Ollama/LM Studio use:
# TUTOR_LLM_COMPLETION_LIMIT_PARAM=max_tokens

# When true, store every LLM request/response in llm_exchange_logs (direction sent|received, user_id when known).
# High volume and may contain sensitive content — use only for debugging.
# TUTOR_LOG_LLM=true
# TUTOR_LOG_LLM_MAX_PAYLOAD_BYTES=2000000
# Also log POST /v1/images/generations (same table; endpoint column). Omit to mirror TUTOR_LOG_LLM. Never stores base64 image data.
# TUTOR_LOG_IMAGE_GENERATION=true

# Lesson generation pipeline (Phase 7.3): optional per-step models (empty = use TUTOR_DEFAULT_LLM_MODEL)
# TUTOR_LESSON_GEN_ROLES_MODEL=
# TUTOR_LESSON_GEN_OUTLINE_MODEL=
# TUTOR_LESSON_GEN_CONTENT_MODEL=
# TUTOR_LESSON_GEN_ROLES_MAX_TOKENS=2048
# TUTOR_LESSON_GEN_OUTLINE_MAX_TOKENS=4096
# The app uses at least this value or a higher floor derived from TUTOR_LESSON_GEN_OUTLINE_MAX_SCENES so outlines are not truncated mid-stream.
# Optional bounds for how many scenes the outline step may include (model picks a natural count in range unless the user specifies a count in the requirement text).
# TUTOR_LESSON_GEN_OUTLINE_MIN_SCENES=1
# TUTOR_LESSON_GEN_OUTLINE_MAX_SCENES=20
# TUTOR_LESSON_GEN_CONTENT_MAX_TOKENS=8192
# TUTOR_LESSON_GEN_PLACEHOLDER_ACTIONS=true
# TUTOR_LESSON_GEN_STREAM_OUTLINE=true
OPENAI_API_KEY=

# POST /api/chat: PHP max execution, Guzzle timeouts, request limits (Phase 3.5)
TUTOR_CHAT_MAX_EXECUTION=120
TUTOR_CHAT_GUZZLE_TIMEOUT=115
TUTOR_CHAT_CONNECT_TIMEOUT=15
TUTOR_CHAT_MAX_MESSAGES=200
TUTOR_CHAT_MAX_CONTENT_BYTES=500000

# Studio LLM generation (Phase 4.5) — scene-outlines-stream, scene-actions, scene-content, agent-profiles
TUTOR_STUDIO_GEN_TEMPERATURE=0.35
TUTOR_STUDIO_GEN_MAX_TOKENS=4096
# TUTOR_STUDIO_GEN_MAX_INSTRUCTION_CHARS=8000
TUTOR_STUDIO_GEN_SSE_CHUNK_CHARS=120

# POST /api/generate/* rate limit (Phase 4.6); 0 = disabled (evaluated per request via middleware)
TUTOR_GENERATE_THROTTLE_PER_MINUTE=60

# Phase 6 — POST /api/chat, /api/parse-pdf, lesson generation, publish; 0 = disabled
TUTOR_CHAT_THROTTLE_PER_MINUTE=60
TUTOR_PARSE_PDF_THROTTLE_PER_MINUTE=30
TUTOR_GENERATE_LESSON_THROTTLE_PER_MINUTE=20
# GET /api/generate-lesson/{id} polling (separate from POST so previews don’t exhaust create limit); 0 = off
TUTOR_GENERATE_LESSON_POLL_THROTTLE_PER_MINUTE=300
TUTOR_PUBLISH_THROTTLE_PER_MINUTE=30

# Behind nginx/traefik: trust proxy headers (comma-separated IPs, or * for any — use only on a locked-down network path)
# TRUSTED_PROXIES=*

# PDF text extraction (Phase 5) — POST /api/parse-pdf (smalot/pdfparser)
TUTOR_PDF_MAX_FILE_BYTES=15000000
TUTOR_PDF_MAX_PAGES=200
TUTOR_PDF_MAX_OUTPUT_CHARS=500000
TUTOR_PDF_MAX_EXECUTION=60
# REQUIRED for “use my PDF’s diagrams in slides”: Poppler pdftoppm must be on PATH (sudo apt install poppler-utils).
# Without it, only PDF text is extracted; the AI never sees page images and cannot emit pdf_page:1 placeholders.
TUTOR_PDF_PAGE_IMAGES=true
TUTOR_PDF_PAGE_IMAGES_MAX=3
TUTOR_PDF_PAGE_IMAGES_SCALE=900
TUTOR_PDF_PAGE_IMAGES_DPI=110
# TUTOR_PDF_TOPPM_PATH=/usr/bin/pdftoppm
# Send page thumbnails to the lesson LLM (needs a vision-capable model)
TUTOR_LESSON_GEN_CONTENT_VISION=true
TUTOR_LESSON_GEN_MAX_PDF_IMAGES=4
# TUTOR_LESSON_GEN_MAX_PDF_IMAGE_CHARS=700000
# Max DALL·E (or compatible) images per lesson when “Image generation” is checked and no PDF images
# TUTOR_LESSON_GEN_AI_SLIDE_IMAGES_MAX=12
# Copy Wikimedia slide fallback diagrams to public disk (same-origin /storage URLs; avoids browser hotlink failures)
# TUTOR_MIRROR_WIKIMEDIA_FALLBACK=true
# Slide fallback: inject Commons keyword diagrams + optional Wikipedia image search when slides lack images.
# Master switch: omitted or commented = default TRUE. Use an explicit line to turn off:
# TUTOR_SLIDE_VISUAL_FALLBACK=false
# TUTOR_SLIDE_VISUAL_FALLBACK=true
# If slide fallback is on: Wikipedia Commons search only (not the keyword diagram list). False = skip en.wikipedia.org API.
# TUTOR_SLIDE_FALLBACK_WIKIMEDIA=true

# Lesson HTML ZIP export (Phase 5) — GET tutor-api/lessons/{id}/export/html-zip
TUTOR_EXPORT_MAX_SCENES=500
TUTOR_EXPORT_MAX_SCENE_JSON_CHARS=200000
TUTOR_EXPORT_MAX_UNCOMPRESSED_BYTES=5000000

# Generated media from POST /api/generate/* (Phase 4.1+) — disk must match config/filesystems.php
TUTOR_MEDIA_GENERATION_DISK=public
TUTOR_MEDIA_GENERATION_PATH_PREFIX=generated

# OpenAI-compatible image generation (Phase 4.2) — POST /api/generate/image; also lesson slides without PDF thumbnails
# Prefer UPPERCASE (Laravel convention). Lowercase tutor_image_api_key / tutor_image_ai_key are also read by config.
# TUTOR_IMAGE_API_KEY=
# TUTOR_IMAGE_AI_KEY=
# TUTOR_IMAGE_BASE_URL=https://api.openai.com/v1
# If you only use Nano Banana (integrations catalog): set IMAGE_NANO_BANANA_API_KEY below and either TUTOR_IMAGE_BASE_URL
# or TUTOR_NANO_BANANA_IMAGE_BASE_URL to that provider’s OpenAI-compatible root (must include /v1 if the API expects it).
# TUTOR_NANO_BANANA_IMAGE_BASE_URL=
TUTOR_OPENAI_IMAGE_MODEL=dall-e-3
# GPT Image models (gpt-image-1, etc.) reject response_format; the app omits it for those models automatically.
# Landscape recommended for lesson slides (DALL·E 3: 1792x1024, 1024x1792, or 1024x1024)
TUTOR_IMAGE_DEFAULT_SIZE=1792x1024
# TUTOR_IMAGE_MAX_PROMPT_CHARS=4000
# TUTOR_IMAGE_REQUEST_TIMEOUT=120
# Transient HTTP retries per image (429 / 502 / 503 / 504 / connection errors); total attempts = this value.
# TUTOR_IMAGE_HTTP_MAX_ATTEMPTS=2

# OpenAI-compatible TTS (Phase 4.3 / 7.6) — POST /api/generate/tts (requires logged-in user; audio cached under generated/tts-cache/)
# TUTOR_TTS_API_KEY=
# TUTOR_TTS_BASE_URL=https://api.openai.com/v1
TUTOR_OPENAI_TTS_MODEL=tts-1
TUTOR_OPENAI_TTS_VOICE=alloy
TUTOR_OPENAI_TTS_FORMAT=mp3
# TUTOR_TTS_MAX_INPUT_CHARS=4096
# TUTOR_TTS_REQUEST_TIMEOUT=120

# MiniMax async text-to-video (Phase 4.4) — POST /api/generate/video, GET /api/generate/video/{jobId}
# Prefer TUTOR_VIDEO_API_KEY or reuse VIDEO_MINIMAX_API_KEY from the integrations block below.
# TUTOR_VIDEO_API_KEY=
# TUTOR_VIDEO_MINIMAX_BASE_URL=https://api.minimax.io
TUTOR_VIDEO_MINIMAX_MODEL=MiniMax-Hailuo-2.3
# TUTOR_VIDEO_MAX_PROMPT_CHARS=2000
# TUTOR_VIDEO_POLL_INTERVAL_SECONDS=5
TUTOR_VIDEO_POLL_INTERVAL_MS=5000
# TUTOR_VIDEO_POLL_MAX_SECONDS=600
# TUTOR_VIDEO_SUBMIT_TIMEOUT=60
# TUTOR_VIDEO_QUERY_TIMEOUT=30
# TUTOR_VIDEO_RETRIEVE_TIMEOUT=60
# TUTOR_VIDEO_DOWNLOAD_TIMEOUT=300

# -----------------------------------------------------------------------------
# Tutor: integrations catalog (GET /api/integrations) — env prefix → Settings card
# Pattern: {PREFIX}_API_KEY; LLM also supports {PREFIX}_BASE_URL and {PREFIX}_MODELS (comma-separated).
# TTS/ASR: API key and/or base URL. PDF: base URL required to show as configured. Image/Video: API key.
# Full map: config/tutor.php
# -----------------------------------------------------------------------------

# --- LLM (OPENAI_API_KEY is set in the default LLM block above) ---
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODELS=
GOOGLE_API_KEY=
GOOGLE_BASE_URL=
GOOGLE_MODELS=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=
DEEPSEEK_MODELS=
QWEN_API_KEY=
QWEN_BASE_URL=
QWEN_MODELS=
KIMI_API_KEY=
KIMI_BASE_URL=
KIMI_MODELS=
MINIMAX_API_KEY=
MINIMAX_BASE_URL=
MINIMAX_MODELS=
GLM_API_KEY=
GLM_BASE_URL=
GLM_MODELS=
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=
SILICONFLOW_MODELS=
DOUBAO_API_KEY=
DOUBAO_BASE_URL=
DOUBAO_MODELS=
GROK_API_KEY=
GROK_BASE_URL=
GROK_MODELS=

# --- TTS (speech) ---
TTS_OPENAI_API_KEY=
TTS_OPENAI_BASE_URL=
TTS_AZURE_API_KEY=
TTS_AZURE_BASE_URL=
TTS_AZURE_REGION=
TTS_GLM_API_KEY=
TTS_GLM_BASE_URL=
TTS_QWEN_API_KEY=
TTS_QWEN_BASE_URL=
TTS_DOUBAO_API_KEY=
TTS_DOUBAO_BASE_URL=
TTS_ELEVENLABS_API_KEY=
TTS_ELEVENLABS_BASE_URL=
TTS_MINIMAX_API_KEY=
TTS_MINIMAX_BASE_URL=

# --- ASR (speech-to-text) ---
ASR_OPENAI_API_KEY=
ASR_OPENAI_BASE_URL=
ASR_QWEN_API_KEY=
ASR_QWEN_BASE_URL=

# --- PDF extraction backends ---
PDF_UNPDF_BASE_URL=
PDF_MINERU_BASE_URL=

# --- Image generation ---
IMAGE_SEEDREAM_API_KEY=
IMAGE_QWEN_IMAGE_API_KEY=
IMAGE_NANO_BANANA_API_KEY=
IMAGE_MINIMAX_API_KEY=
IMAGE_GROK_API_KEY=

# --- Video generation ---
VIDEO_SEEDANCE_API_KEY=
VIDEO_KLING_API_KEY=
VIDEO_VEO_API_KEY=
VIDEO_SORA_API_KEY=
VIDEO_MINIMAX_API_KEY=
# VIDEO_MINIMAX_BASE_URL=https://api.minimax.io
VIDEO_GROK_API_KEY=

# --- Web search ---
TAVILY_API_KEY=

# If you see tempnam() / "system's temporary directory" errors, PHP cannot write under storage/.
# Either fix ownership (e.g. chown -R www-data:www-data storage bootstrap/cache) or use paths under /tmp:
# VIEW_COMPILED_PATH=/tmp/mytutor/views
# SESSION_FILES_PATH=/tmp/mytutor/sessions

# Use `file` for local dev if MySQL is not running yet. Use `database` in production (requires `sessions` table — run migrations).
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Use phpredis only if the php-redis extension is installed; otherwise predis (Composer) is used.
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
