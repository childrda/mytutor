<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <env name="APP_ENV" value="testing"/>
        <env name="LOG_CHANNEL" value="errorlog"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="array" force="true"/>
        <!-- MySQL + RefreshDatabase: DB_HOST/DB_USERNAME/DB_PASSWORD come from your environment or .env (not set here). -->
        <env name="DB_CONNECTION" value="mysql" force="false"/>
        <env name="DB_DATABASE" value="mytutor_test" force="false"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="sync"/>
        <env name="SESSION_DRIVER" value="array" force="true"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <!-- Avoid streaming outline in tests (extra HTTP + fragile fakes). -->
        <env name="TUTOR_LESSON_GEN_STREAM_OUTLINE" value="false" force="true"/>
        <env name="TUTOR_LOG_LLM" value="false" force="true"/>
        <!-- Unit tests expect direct Wikimedia URLs; mirroring would require HTTP fakes per test. -->
        <env name="TUTOR_MIRROR_WIKIMEDIA_FALLBACK" value="false" force="true"/>
        <!-- Do not inherit dev .env TUTOR_SLIDE_VISUAL_FALLBACK=false — SlideVisualFallback tests need fallback on. -->
        <env name="TUTOR_SLIDE_VISUAL_FALLBACK" value="true" force="true"/>
        <env name="TUTOR_SLIDE_FALLBACK_WIKIMEDIA" value="true" force="true"/>
    </php>
</phpunit>
